{
  "expo": {
    "name": "CareVoy",
    "slug": "carevoy",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "carevoy",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050D1F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.carevoy.app",
      "buildNumber": "30",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CareVoy uses your location to auto-fill your pickup address.",
        "NSCalendarsUsageDescription": "CareVoy adds your ride to your calendar so you never miss an appointment.",
        "NSContactsUsageDescription": "CareVoy can access contacts to help you add emergency contacts quickly.",
        "NSPhotoLibraryUsageDescription": "CareVoy uses your photo library so you can set a profile photo.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://carevoy.co/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image-picker",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.co.carevoy",
          "enableGooglePay": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CareVoy uses your location to auto-fill your pickup address."
        }
      ],
      "@sentry/react-native/expo"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "5ff188f5-4996-403d-81fb-ba2e7e7c6988"
      }
    }
  }
}