{
  "expo": {
    "name": "CareVoy",
    "slug": "workspace",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "carevoy",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050D1F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.carevoy.app",
      "buildNumber": "59",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CareVoy uses your location to find nearby pickup points and show your ride on the map.",
        "NSCalendarsUsageDescription": "CareVoy adds your ride to your calendar so you never miss an appointment.",
        "NSContactsUsageDescription": "CareVoy can access contacts to help you add emergency contacts quickly.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "CareVoy sends you ride updates, pickup reminders, and receipt notifications."
      }
    },
    "android": {
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://carevoy.co/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.co.carevoy",
          "enableGooglePay": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "CareVoy adds your ride to your calendar so you never miss an appointment."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "f70bca6e-82e7-4cea-8455-4d6077dcb765"
      }
    },
    "owner": "carevoy"
  }
}